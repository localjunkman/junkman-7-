{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/services-5", "destination": "/services/", "permanent": true },
    { "source": "/general-4", "destination": "/pricing/", "permanent": true },
    { "source": "/book-online", "destination": "/contact/", "permanent": true },
    { "source": "/accessibility-statement", "destination": "/contact/", "permanent": true },
    { "source": "/post/junk-removal-in-carlsbad-encinitas-la-costa", "destination": "/blog/junk-removal-carlsbad-encinitas/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
