{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/services-5",
      "destination": "/services/",
      "permanent": true
    },
    {
      "source": "/general-4",
      "destination": "/pricing/",
      "permanent": true
    },
    {
      "source": "/book-online",
      "destination": "/contact/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/accessibility-statement",
      "destination": "/contact/",
      "permanent": true
    },
    {
      "source": "/post/junk-removal-in-carlsbad-encinitas-la-costa",
      "destination": "/blog/junk-removal-carlsbad-encinitas/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
